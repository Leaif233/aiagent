# ===== AI Technical Support System =====

# Anthropic API Key (for Claude LLM)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# DeepSeek API Key (alternative LLM provider)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# DashScope API Key (for remote embeddings)
DASHSCOPE_API_KEY=your-dashcope-api-key-here

# Redis URL (for Celery async tasks)
REDIS_URL=redis://localhost:6379/0

# JWT Secret (auto-generated if not set)
JWT_SECRET=your-jwt-secret-here

# CORS allowed origins (comma-separated, default: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173
